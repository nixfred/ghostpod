# Tailscale (optional)
# When set, Caddy joins your tailnet and gets a real TLS cert automatically.
# When unset, Caddy uses a self-signed internal CA (run `caddy trust` to install
# the CA on each device, or accept the browser warning).
#
# Generate an auth key at: https://login.tailscale.com/admin/settings/keys
# Use a reusable, ephemeral key so the node re-auths on redeploy.
TS_AUTHKEY=

# The name Caddy registers as on your tailnet (e.g. ghostpod.<tailnet>.ts.net).
# This does not need to match an existing machine name in the admin console.
TS_HOSTNAME=ghostpod

# LAN mode only: the IP or hostname browsers will use to reach this service.
# Caddy issues its internal TLS cert with this as the Subject Alternative Name.
# If you set up a local DNS entry (e.g. terminal.lan), use that here instead.
LAN_HOST=192.168.1.100

# BasicAuth credentials (leave both empty to run without auth)
# Generate the password hash:
#   docker run --rm caddy:latest caddy hash-password --plaintext 'yourpassword'
ADMIN_USER=
# Leave empty to start without auth (safe for initial deploy — set before exposing the service).
# Generate a hash: docker run --rm caddy:latest caddy hash-password --plaintext 'yourpassword'
# Escape every $ in the hash as $$ so docker-compose doesn't expand it as a variable.
ADMIN_PASSWORD_HASH=

# Signs session cookies — generate with: openssl rand -hex 32
# If unset, a random key is generated at startup (sessions invalidated on restart).
SECRET_KEY=
